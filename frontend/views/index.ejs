<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>Form Submission Application</h1>
            <p>Submit your information below</p>
        </header>

        <nav>
            <a href="/">Home</a>
            <a href="/submissions">View All Submissions</a>
        </nav>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error">
                <strong>Error:</strong> <%= error %>
            </div>
        <% } %>

        <form method="POST" action="/submit" class="form">
            <div class="form-group">
                <label for="name">Full Name:</label>
                <input type="text" id="name" name="name" required placeholder="Enter your full name"
                    value="<%= typeof formData !== 'undefined' && formData.name ? formData.name : '' %>">
            </div>

            <div class="form-group">
                <label for="email">Email Address:</label>
                <input type="email" id="email" name="email" required placeholder="Enter your email"
                    value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>">
            </div>

            <div class="form-group">
                <label for="message">Message:</label>
                <textarea id="message" name="message" required placeholder="Enter your message" rows="5"><%= typeof formData !== 'undefined' && formData.message ? formData.message : '' %></textarea>
            </div>

            <button type="submit" class="btn">Submit Form</button>
        </form>

        <footer>
            <p>&copy; 2024 Form Submission Application. All rights reserved.</p>
        </footer>
    </div>
</body>
</html>
